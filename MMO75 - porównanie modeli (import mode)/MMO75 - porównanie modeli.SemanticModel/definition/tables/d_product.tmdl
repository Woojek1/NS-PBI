	partition d_product = m
		mode: import
		source =
				let
				    d_product = Value.NativeQuery(
				    Databricks.Catalogs(
				        "adb-16306551450739.19.azuredatabricks.net",
				        "/sql/1.0/warehouses/d77ff9935cb3e9fe",
				        [Catalog="zenith", Database=null, QueryTags=null, EnableAutomaticProxyDiscovery=null, Implementation=null]
				    ){[Name="zenith", Kind="Database"]}[Data],
				    "
				    select
				        p.prod_si_id,
				        p.line_name        as `Line`,
				        p.model_code       as `Model Code`,
				        p.model_name       as `Model`,
				        p.sgrp_name        as `Product Subgroup`,
				        p.supergrp_name    as `Product Supergroup`,
				        p.grp_name         as `Product Group`,
				        p.prod_si_name     as `Index Name`,
				        p.prod_si_code     as `Index Code`,
				       p.brand_name        as `Brand`
				--p.bcg1_name_en     as `Business category`,
				--p.bcg2_name_en     as `Business subcategory`,
				--p.bcg3_name_en     as `Business cluster`,
				--case
				--when p.line_status_name = 'PrzesuniÄ™te' then 'Przesunięte'
				--else p.line_status_name
				--end as `Line status`,
				--p.line_novelties_flag as `Novelties flag`,
				--p.npi_no           as `NPI No`,
				        -- case
				        --     when npi_no is null then false
				        --     else true
				        -- end                as `NPI flag`,
				        -- p.price_model_name as `Pricelist model name`
				    from zenith.edw.d_product p
				    where exists (
				        select 1
				        from zenith.mmo75.f_margin_ytd_delta_facts f
				        where f.prod_inv_id = p.prod_si_id
				    )
				    ",
				    null,
				    [EnableFolding=true]
				    )
				in
				    d_product

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

