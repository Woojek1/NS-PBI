model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pl-PL
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["d_product","tkw_today","pricelist"]

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

ref table d_product
ref table tkw_today
ref table pricelist
ref table _Measures

ref cultureInfo en-US

