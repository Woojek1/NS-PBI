table RoleDaxFilter_Cust
	lineageTag: 411d148a-f77f-4e0a-83a5-db0e279b844d

	column user_name
		dataType: string
		lineageTag: 3552ef12-a6b0-4108-b024-1f7af11579e9
		summarizeBy: none
		sourceColumn: user_name

		annotation SummarizationSetBy = Automatic

	column cust_id
		dataType: int64
		formatString: 0
		lineageTag: 129dacf6-7ebf-4c3f-9cde-547e74e249ae
		summarizeBy: none
		sourceColumn: cust_id

		annotation SummarizationSetBy = Automatic

	partition RoleDaxFilter_Cust = m
		mode: import
		source = ```
				Value.NativeQuery(
				    Databricks.Catalogs(
				        "adb-16306551450739.19.azuredatabricks.net",
				        "/sql/1.0/warehouses/d77ff9935cb3e9fe",
				        [Catalog="zenith", Database=null, QueryTags=null, EnableAutomaticProxyDiscovery=null, Implementation=null]
				    ){[Name="zenith", Kind="Database"]}[Data],
				    "
				select 
				    r.user_name,
				    o.cust_id
				from
				    zenith.edw.role_dax_filter_config r
				join
				    zenith.edw.d_customer o 
				on 
				    o.country_code = r.value_code
				where
				    r.privilege_grp='MMO_MODEL' and r.col_name='COUNTRY_NAME'
				
				UNION ALL
				
				select
				    r.user_name,
				    o.cust_id
				from
				    zenith.edw.role_dax_filter_config r
				join 
				    zenith.edw.d_customer o 
				on
				    o.mseg_code = r.value_code
				where
				    r.privilege_grp='MMO_MODEL' and r.col_name='MSEG_CODE'
				
				UNION ALL
				
				select
				    r.user_name,
				    o.cust_id
				from
				    zenith.edw.role_dax_filter_config r
				join
				    zenith.edw.d_customer o 
				on
				    o.cust_code = r.value_code
				where
				    r.privilege_grp='MMO_MODEL' and r.col_name='CUST_CODE'
				
				UNION ALL
				
				select
				    r.user_name,
				    o.cust_id
				from
				    zenith.edw.role_dax_filter_config r
				join
				    zenith.edw.d_customer o
				on
				    o.cust_hier_code = r.value_code
				where
				    r.privilege_grp='MMO_MODEL' and r.col_name='HIERARCHY_CODE'
				",
				    null,
				    [EnableFolding=true]
				)
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

