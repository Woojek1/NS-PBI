table RoleDaxFilter_Org
	lineageTag: 176b8cbc-bf41-47e9-9f85-8561b988873e

	column user_name
		dataType: string
		lineageTag: 414e9796-a241-4ef1-a668-3b8e8b6172ea
		summarizeBy: none
		sourceColumn: user_name

