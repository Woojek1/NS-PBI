	partition RoleDaxFilter_Comp = m
		mode: directQuery
		source = ```
				let
				    Source = Sql.Database(
				        "sql-solet-prod.database.windows.net",
				        "SQLDB-solet-prod_01"
				    ),
				
				    Query = "
				        SELECT 
				            r.user_name, 
				            t.comp_id
				        FROM v_role_dax_filter_config AS r
				        INNER JOIN vd_company AS t
				            ON t.comp_name_s = r.value_code COLLATE SQL_Latin1_General_CP1_CI_AS
				        WHERE 
				            r.privilege_grp = 'MMO_MODEL'
				            AND r.col_name = 'COMP_NAME_S'
				    ",
				
				    Result = Value.NativeQuery(
				        Source,
				        Query,
				        null,
				        [EnableFolding = true]
				    )
				in
				    Result
				```

