	partition RoleDaxFilter_Comp = m
		mode: import
		source = ```
				Value.NativeQuery(
				    Databricks.Catalogs(
				        "adb-16306551450739.19.azuredatabricks.net",
				        "/sql/1.0/warehouses/d77ff9935cb3e9fe",
				        [Catalog="zenith", Database=null, QueryTags=null, EnableAutomaticProxyDiscovery=null, Implementation=null]
				    ){[Name="zenith", Kind="Database"]}[Data],
				    "
				    SELECT 
				        r.user_name, 
				        t.comp_id
				    FROM
				        zenith.edw.role_dax_filter_config r
				    INNER JOIN
				        zenith.edw.d_company t
				    ON
				        t.comp_name_s = r.value_code
				    WHERE 
				        r.privilege_grp = 'MMO_MODEL'
				    AND r.col_name = 'COMP_NAME_S'
				    ",
				    null,
				    [EnableFolding=true]
				)
				```

